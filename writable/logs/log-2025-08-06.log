 8 APPPATH\Controllers\Student\chapter.php(81): Mpdf\Mpdf->WriteHTML('<div style="font-family: mangal; font-size: 18px; line-height: 1.8; text-align: justify;"><div class="wp-block-group has-global-padding is-layout-constrained wp-block-group-is-layout-constrained"> <h1 class="has-text-align-center wp-block-post-title has-x-large-font-size">Unit I-Computer System Concept</h1> <div class="wp-block-spacer" aria-hidden="true"> </div> </div> <div class="entry-content wp-block-post-content has-global-padding is-layout-constrained wp-block-post-content-is-layout-constrained"> <div class="wp-block-columns is-layout-flex wp-container-core-columns-is-layout-28f84493 wp-block-columns-is-layout-flex"> <div class="wp-block-column is-layout-flow wp-block-column-is-layout-flow"> <h2 class="wp-block-heading"><span lang="hi" class="lang_hi">कम्‍प्‍यूटर की परिभाषा:-</span></h2> <p><span lang="hi" class="lang_hi">कम्‍प्‍यूटर एक इलेक्ट्रानिक मशीन होती है। यह अंकगणितीय और तार्किक कार्यों (लाजीकल आपरेशन) को सम्‍पन्‍न करती है। कम्‍प्‍यूटर को निर्देशों की एक सूची दी जाती है। कम्प्यूटर इन निर्देशों के अनुसार डाटा को बहुत ही तेज गति से, बिना कोई गलती किये, लगातार, व्‍यवस्थित (मैनीपूलेट/प्रासेस) कर सकता है।</span></p> <p> </p> <h3 class="wp-block-heading"><span lang="hi" class="lang_hi">कम्‍प्‍यूटर सिस्‍टम:-</span></h3> <p><span lang="hi" class="lang_hi">कम्‍प्‍यूटर सिस्‍टम की इनपुट यूनिट के द्वारा “अप्रसंस्कृत डेटा” सेट कम्प्यूटर को दिया जाता है। कम्प्यूटर इस डाटा को सीपीयू में प्रोसेस करके संवर्धित, व्यवस्थित एवं अर्थपूर्ण डाटा सेट का निर्माण करता है। संवर्धित डाटा के सेट को आउटपुट यूनिट की सहायता से हमारे सामने प्रदर्शित करता है। इस कार्य हेतु हार्डवेयर तथा साफ्टवेयर के कम्‍बीनेशन की आवश्‍यकता होती है।</span></p> <p><span lang="hi" class="lang_hi">कम्‍प्‍यूटर सिस्‍टम में एक कम्‍प्‍यूटर तथा उनसे संबंधित साफ्टवेयर का समूह होता है। कम्‍प्‍यूटर सिस्‍टम में यूजर अपना डाटा इनपुट, मैनुपलेट तथा स्‍टोर कर सकता है। कम्‍प्‍यूटर सिस्‍टम से संबंधित महत्‍वपूर्ण शब्दों की परिभाषा निम्‍न है।</span></p> <h4 class="wp-block-heading"><span lang="hi" class="lang_hi">यूजर:-</span></h4> <p><span lang="hi" class="lang_hi">कम्‍प्‍यूटर सिस्‍टम में यूजर दो तरह के होते है। एक जो कम्‍प्‍यूटर पर प्रोग्राम का प्रयोग करते है। दूसरे यूजर वह होते है जो उन प्रोग्राम को बनाते है।</span></p> <h4 class="wp-block-heading"><span lang="hi" class="lang_hi">डाटा:-</span></h4> <p><span lang="hi" class="lang_hi">कम्‍प्‍यूटर में स्‍टोर या प्रोसेस की गई सूचना डाटा होती है। यह जानकारी टैक्‍सट डाक्‍यूमेंट, इमेज, आडियो,वीडियो या साफ्टवेयर प्रोग्राम के रूप में हो सकते है।</span></p> <h4 class="wp-block-heading"><span lang="hi" class="lang_hi">हार्डवेयर:-</span></h4> <p><span lang="hi" class="lang_hi">हार्डवेयर शब्‍द का अर्थ कम्‍प्‍यूटर के उन फिजिकल भागों है जिन्‍हें हम छू सकते है, जैसे – मानीटर, हार्ड डिस्‍क, ड्राइव, माइक्रो प्रोसेसर इत्‍यादि।</span></p> <h4 class="wp-block-heading"><span lang="hi" class="lang_hi">साफ्टवेयर :-</span></h4> <p><span lang="hi" class="lang_hi">साफ्टवेयर कम्‍प्‍यूटर सिस्‍टम पर रन होने वाले प्रोग्राम है। इसके तहत आपरेटिंग सिस्‍टम तथा कम्‍प्‍यूटर पर रन होने वाले अन्‍य साफ्टवेयर प्रोग्राम शामिल है।</span></p> <p><img src="http://localhost/ci45/public/uploads/chapters/1754286777_0b56f368dfc587d48914.webp" alt="" width="1024" height="684"></p> <h2 class="wp-block-heading"><span lang="hi" class="lang_hi">कम्‍प्‍यूटर के मूलभूत उपयोग</span>(Application Area)<strong>:-</strong></h2> <h3 class="wp-block-heading"><span lang="hi" class="lang_hi">शिक्षा के</span><strong> </strong><span lang="hi" class="lang_hi">क्षेत्र में कंप्यूटर का उपयोग:-</span></h3> <p><span lang="hi" class="lang_hi">कंप्यूटर का उपयोग शिक्षा में इंटरैक्टिव शिक्षण, ऑनलाइन पाठ्यक्रम, अनुसंधान और शैक्षिक विषय वस्‍तु तक पहुंच के लिए किया जाता है। आभासी</span>(virtual class) <span lang="hi" class="lang_hi">कक्षाओं और दूरस्थ शिक्षण</span>(distance education) <span lang="hi" class="lang_hi">बिना कम्‍प्‍यूटर के संभव नहीं होंगी ।</span></p> <p><span lang="hi" class="lang_hi">कम्‍प्‍यूटर एक शिक्षक के रूप में भी कार्य करने लगे हैं। “कम्‍प्‍यूटर असिस्‍टेड इंन्‍सट्रक्‍शन” (सी.ए.आई.), एक साफ्टवेयर होता है जो कम्‍प्‍यूटर को एक शिक्षक का रूप देता है।  हर व्‍यक्ति कम्‍प्‍यूटर सीखने का इच्‍छुक है। फलस्‍वरूप विश्‍वविद्यालय में नए-नए पाठ्यक्रमों लागू हो रहे है। कम्‍प्‍यूटर विज्ञान, सूचना प्रौद्योगिकी शिक्षा देने हेतु संस्‍थानो की संख्‍या प्रतिदिन बढ़ रही है।</span></p> <p><span lang="hi" class="lang_hi">स्कूल में कंप्यूटर का उपयोग</span> Computer Lab <span lang="hi" class="lang_hi">में छात्रों को कंप्यूटर सिखाने के लिए किया जाता है।</span></p> <p><span lang="hi" class="lang_hi">स्कूल तथा कॉलेज में कंप्यूटर का उपयोग फॉर्म भरने, डेटा एंट्री तथा स्कूल व कॉलेज से रिलेटेड</span> document <span lang="hi" class="lang_hi">को सेव रखने , परिक्षा के प्रश्‍नपत्र प्रिन्ट करने के लिए भी किया जाता है।</span></p> <h3 class="wp-block-heading"><span lang="hi" class="lang_hi">बैंक में कंप्यूटर का उपयोग:-</span></h3> <p><span lang="hi" class="lang_hi">बैंकों में कंप्यूटर का उपयोग ज्यादातर विभिन्न प्रकार के फॉर्म भरने तथा पैसों के लेनदेन को सुरक्षित रखने के लिए किया जाता है। कंप्यूटर का उपयोग बैंकों के लिए बहुत जरूरी है। क्योंकि कंप्यूटर के बिना पैसों के लेनदेन को मैनेज करना काफी मुश्किल होता।</span></p> <p><span lang="hi" class="lang_hi">कंप्यूटर की मदद से ही बैंकों में एक खाताधारक के खाते से दूसरे किसी इंसान के खाते में पैसे को आसानी से भेजा जाता है। बैंक में खाता खोलने से लेकर अन्‍य कई सुविधाओं के फॉर्म को कम्‍प्‍यूटर से आनलाइन आसानी से</span> Submit <span lang="hi" class="lang_hi">किया जाता है।</span></p> <h3 class="wp-block-heading"><span lang="hi" class="lang_hi">व्यवसाय में कंप्यूटर का उपयोग:-</span></h3> <p><span lang="hi" class="lang_hi">व्यवसाय संचालन, रिकॉर्ड रखने, लेखांकन, वित्तीय विश्लेषण और ऑनलाइन लेनदेन के लिए कंप्यूटर आवश्यक हैं। इनका उपयोग इन्वेंट्री प्रबंधन, ग्राहक संबंध प्रबंधन(सीआरएम और इलेक्ट्रॉनिक कॉमर्स, ई-कॉमर्स)के लिए भी किया जाता है।</span></p> <p><span lang="hi" class="lang_hi">कंप्यूटर का उपयोग सबसे ज्यादा व्यवसाय के क्षेत्र में ही किया जाता है।</span></p> <p><span lang="hi" class="lang_hi">व्यवसाय में कंप्यूटर का उपयोग कर्मचारियों की व्‍यक्तिगत जानकारी, वेतन डिटेल, उपस्थिति का रिकार्ड रखने के लिये भी  किया जाता है। कंपनी के उत्‍पाद का प्रचार प्रसार भी कम्‍प्‍यूटर से आसानी से भी किया जाता है। व्यवसाय के क्षेत्र में कागजी काम काफी ज्यादा होता है। लेकिन कंप्यूटर के आने के बाद से कागजी काम काफी कम हो गया है।</span></p> <h3 class="wp-block-heading"><span lang="hi" class="lang_hi">चिकित्सा के क्षेत्र में कंप्यूटर का उपयोग:-</span></h3> <p><span lang="hi" class="lang_hi">कंप्यूटर का उपयोग रोगी रिकॉर्ड प्रबंधन, फॉर्म भरने तथा रिपोर्ट तैयार करने में कंप्यूटर का उपयोग किया जाता है। चिकित्सा इमेजिंग, डिजिटल एक्‍सरे(जैसे एक्स-रे और एमआरआई),दवा अनुसंधान और चिकित्सा निदान के लिए किया जाता है। टेली मेडिसिन भी कम्‍प्‍यूटर से ही संभव होती है, इसमें डॉक्टरों को दूर से ही मरीजों का निदान और इलाज करने की सुविधा मिलती है।</span></p> <p>X-ray, CT-scan, Ultrasound <span lang="hi" class="lang_hi">इत्यादि कंप्यूटर की मदद से ही किया जाता है। कंप्यूटर के आने के बाद से चिकित्सा क्षेत्र में भी काफी बदलाव देखने को मिला है।</span></p> <h3 class="wp-block-heading"><span lang="hi" class="lang_hi">डिज़ाइन और इंजीनियरिंग के क्षेत्र में कंप्यूटर का उपयोग:-  </span></h3> <p><span lang="hi" class="lang_hi">आर्किटेक्ट, इंजीनियरों और डिज़ाइनरों डिज़ाइन बनाने के लिए, अनुकरण करने और डिजाइन की कल्पना करने के लिए कंप्यूटर उपयोग करते हैं। इंजिनियरिंग क्षेत्रों में कंप्यूटर-एडेड डिज़ाइन</span>(CAD) <span lang="hi" class="lang_hi">और कंप्यूटर-एडेड इंजीनियरिंग</span>(CAE)<span lang="hi" class="lang_hi">सॉफ़्टवेयर का व्यापक रूप से उपयोग किया जाता है।</span></p> <h3 class="wp-block-heading"><span lang="hi" class="lang_hi">संचार के क्षेत्र में कंप्यूटर का उपयोग:-  </span></h3> <p><span lang="hi" class="lang_hi">कंप्यूटर ईमेल, त्वरित संदेश</span> (instant messaging), <span lang="hi" class="lang_hi">वीडियो कॉन्फ्रेंसिंग और सोशल मीडिया सहित संचार के विभिन्न रूपों से आपसी संचार केा सुगम बनाता है। कम्‍प्‍यूटर संचार नेटवर्क और इंटरनेट को भी संभव बनाते हैं, जिससे वैश्विक कनेक्टिविटी संभव होती है।</span></p> <h3 class="wp-block-heading"><span lang="hi" class="lang_hi">परिवहन के क्षेत्र में कंप्यूटर का उपयोग:-  </span></h3> <p><span lang="hi" class="lang_hi">कंप्यूटर से विभिन्न परिवहन प्रणालियों का नियंत्रण एवं प्रबंधन किया जाता है, हवाई यातायात नियंत्रण, रेलवे नेटवर्क, वाहनों में नेविगेशन प्रणाली</span>(GPS) <span lang="hi" class="lang_hi">और प्राइवेट वाहन के प्रबंधन में कम्‍प्‍यूटर का अत्‍यधिक उपयोग होता हैं।</span></p> <h3 class="wp-block-heading"><span lang="hi" class="lang_hi">मौसम पूर्वानुमान के क्षेत्र में कंप्यूटर का उपयोग:-  </span></h3> <p><span lang="hi" class="lang_hi">सुपर कंप्यूटर का उपयोग मौसम के पूर्वानुमान के लिए किया जाता है, इससे प्राकृतिक आपदाओं के बारे में सटीक भविष्यवाणी और चेतावनी मिलती है।</span></p> <h3 class="wp-block-heading"><span lang="hi" class="lang_hi">कृषि के क्षेत्र में कंप्यूटर का उपयोग:-  </span></h3> <p><span lang="hi" class="lang_hi">कंप्यूटर सेंसर, उपग्रह और ड्रोन से डेटा का विश्लेषण करके कृषि कार्य में सहायता करते हैं। इससे रोपाइ, सिंचाई और कटाई की प्रक्रिया व्‍यवस्थित हो जाती है।</span></p><ul class="wp-block-list"><li><span lang="hi" class="lang_hi">कम्‍प्‍यूटरीकृत कार </span></li><li><span lang="hi" class="lang_hi">कम्‍प्‍यूटरी घर</span></li><li><span lang="hi" class="lang_hi">व्‍यक्तिगत रोबोट नौकर  </span></li><li><span lang="hi" class="lang_hi">घर से बैंकिग और खरीददारी </span></li><li><span lang="hi" class="lang_hi">आधुनिक कुटीर उद्योग</span></li><li><span lang="hi" class="lang_hi">रसोई घर में ।</span></li></ul> </div> </div> </div></div>')
 9 SYSTEMPATH\CodeIgniter.php(933): App\Controllers\Student\Chapter->exportPdf('computer-system-concept')
