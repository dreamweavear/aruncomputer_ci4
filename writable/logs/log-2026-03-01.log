 1 SYSTEMPATH/Database/BaseConnection.php(738): CodeIgniter\Database\MySQLi\Connection->execute('INSERT INTO `chapters` (`unit_id`, `name`, `slug`, `content`, `created_at`, `updated_at`) VALUES (\'2\', \'Operating system\', \'operating-system\', \'<div>\\r\\n<div>\\r\\n<h2>हार्डवेयर क्&zwj;या है :-&nbsp;</h2>\\r\\n<p>हार्डवेयर कम्&zwj;प्&zwj;यूटर के बाहरी और आंतरिक उपकरणों को कहते है। ये कम्&zwj;प्&zwj;यूटर के भौतिक भाग होते है। इन उपकरणों के द्वारा कम्&zwj;प्&zwj;यूटर इनपुट, आउटपुट, स्टोरेज, संचार, प्रोसेसिंग जैसे बहतु से प्रमुख कार्य करने में सक्षम होते है। कंप्यूटर हार्डवेयर दो प्रकार के होते हैं: बाहरी और आंतरिक। मानीटर , माउस , कीबोर्ड , हार्ड डिस्&zwj;क, रैम , मदरबोर्ड , प्रासेसर जैसे कम्&zwj;प्&zwj;यूटर के हिस्&zwj;से हार्डवेयर कहलाते है।</p>\\r\\n<h2>सॉफ़्टवेयर क्&zwj;या है :-</h2>\\r\\n<p>सॉफ़्टवेयर के द्वारा कम्&zwj;प्&zwj;यूटर हार्डवेयर केा निर्देश दिया जाता है, कि उसे क्&zwj;या करना है, और कैसे करना है। किसी विशेष कार्य को करने के लिए निर्देषों के समूह को प्रोग्राम कहते है, एक सॉफ़्टवेयर में बहुत से छोटे छोट प्रोग्राम हो सकते है, जो समुहिक रूप से मिलकर एक बड़ा कार्य कर सकते है । कम्&zwj;प्&zwj;यूटर के प्रोग्राम एवं मोबाइल के एप सॉफ़्टवेयर कहलाते है।</p>\\r\\n<h3>Software के प्रकार निम्&zwj;नलिखित है:-</h3>\\r\\n<h3>Application Software :-&nbsp;</h3>\\r\\n<p>&nbsp;&ldquo;एप्लिकेशन सॉफ़्टवेयर&rdquo; कम्&zwj;प्&zwj;यूटर उपयोग करने वाले के लिए विशिष्ट कार्य करता है। एप्लिकेशन सॉफ़्टवेयर को यूजर सीधे उपयोग करता है । एप्लिकेशन सॉफ़्टवेयर का उद्देश्य किसी विशिष्&zwj;ट कार्यों को करने में उपयोगकर्ता को &nbsp;सहायता प्रदान करना है।</p>\\r\\n<p>माइक्रोसॉफ्ट वर्ड एक्सेल, फ़ायरफ़ॉक्स और गूगल क्रोम वेब ब्राउज़र, मोबाइल ऐप्स व्हाट्सएप और कैंडी क्रश सागा जैसे गेम एप्लिकेशन सॉफ़्टवेयर के उदाहरण हैं।</p>\\r\\n<p>लोकप्रिय सेवाओं के ऐप जैसे मौसम या परिवहन जानकारी, ग्लोबल पोजिशनिंग सिस्टम (जीपीएस), ग्राफिक्स, मल्टीमीडिया, प्रेजेंटेशन सॉफ्टवेयर, डेस्कटॉप पब्लिशिंग सॉफ्टवेयर इत्यादि &nbsp;अप्लिकेशन&nbsp; सॉफ्टवेयर के उदाहरण हैं।</p>\\r\\n<h3>System software &ndash;</h3>\\r\\n<p>सिस्टम सॉफ़्टवेयर का उपयोग हार्डवेयर के साथ इंटरैक्ट करने के लिए किया जाता है। ये सॉफ़्टवेयर अन्य सॉफ़्टवेयर के लिए एक प्लेटफ़ॉर्म प्रदान करते है। सिस्टम सॉफ़्टवेयर हार्डवेयर और उपयोगकर्ता के बीच माध्&zwj;यम के रूप में कार्य करता है।ये आमतौर पर कंप्यूटर निर्माताओं द्वारा तैयार किए जाते हैं। इस सॉफ़्टवेयर में निम्न-स्तरीय भाषाओं में लिखे गए प्रोग्राम भी आते हैं,</p>\\r\\n<p>ऑपरेटिंग सिस्टम, एंटीवायरस सॉफ़्टवेयर, डिस्क फ़ॉर्मेटिंग सॉफ़्टवेयर, कंप्यूटर भाषा अनुवादक, डिवाइस ड्राइवर इत्&zwj;यादि सिस्टम सॉफ़्टवेयर के उदाहरण हैं।</p>\\r\\n<h2>Operating system:-</h2>\\r\\n<p>ऑपरेटिंग सिस्&zwj;टम एक &lsquo;सिस्&zwj;टम Software&rsquo; है जो कम्&zwj;प्&zwj;यूटर का आन्&zwj;तरिक संचालन करता है। यह कम्&zwj;प्&zwj;यूटर को हमारे उपयोग के लिए तैयार करता है। यह कम्&zwj;प्&zwj;यूटर स्&zwj;टार्ट करने पर बूट प्रोग्राम द्वारा कंप्यूटर में लोड होता है ।</p>\\r\\n<p>यह कंप्यूटर के हार्डवेयर एवं अन्य सभी एप्लिकेशन प्रोग्राम को संचालित करता है। उपयोगकर्ता कमांड-लाइन इंटरफ़ेस (सीएलआई) या ग्राफिकल यूआई (जीयूआई) के माध्यम से ऑपरेटिंग सिस्टम को निर्देश दे सकते है ।</p>\\r\\n<h3>Window 8.1:-</h3>\\r\\n<p>ऑपरेटिंग सिस्&zwj;टम एक सिस्&zwj;टम Software है जो कम्&zwj;प्&zwj;यूटर का आन्&zwj;तरिक संचालन करता है। यह कम्&zwj;प्&zwj;यूटर को हमारे उपयोग के लिए तैयार करता है। यह कम्&zwj;प्&zwj;यूटर स्&zwj;टार्ट करने पर बूट प्रोग्राम द्वारा कंप्यूटर में लोड होता है ।</p>\\r\\n<ul>\\r\\n<li>Window 8.1 एक ऑपरेटिगं सिस्&zwj;टम है जिसे माइक्रोसॉफ्ट कम्&zwj;पनी ने बनाया है।</li>\\r\\n<li>विंडो ऑपरेटिंग सिस्&zwj;टम में प्रोग्राम एक विंडो में खुलते है।</li>\\r\\n<li>एक साथ कई प्रोग्राम अलग- अलग विंडो में खोले जा सकते है। इसलिए इसे विंडो ऑपरेटिंग सिस्&zwj;टम कहते है।</li>\\r\\n<li>पुराने ऑपरेटिंग सिस्&zwj;टम में (Dos Based) कम्&zwj;प्&zwj;यूटर को कमाण्&zwj;ड या निर्देश टाइप करके दिया जाता था।</li>\\r\\n<li>जिसके कारण हमे सारे कमाण्&zwj;ड याद रखने पड़ते थे। विंडो ऑपरेटिंग सिस्&zwj;टम के विकास के बाद हम कम्&zwj;प्&zwj;यूटर को निर्देश मानीटर पर आइकॉन के उपर&nbsp; क्लिक करके दे सकते &nbsp;है।</li>\\r\\n<li>विंडो 8.1 में पुराने विंडो के संस्&zwj;करण विंडो 8 तक की सभी सुविधाए उपलब्&zwj;ध है, यह ज्&zwj;यादा एडवांस और स्&zwj;टेबल है। इसमे नए ऑनलाइन फीचर और सिक्&zwj;योरिटी जोड़ी गई है।</li>\\r\\n<li>इसका इन्&zwj;टरफेस नया है। इसमे लाइव टाइल और हॉट कॉर्नरस की सुविधाए दी गई है।</li>\\r\\n<li>हमारें प्रोग्राम को सुरक्षित रखने व वायरस से बचाने के लिए विंडो डिफेन्&zwj;डर एन्&zwj;टीवायरस उपलब्&zwj;ध कराया गया है।</li>\\r\\n</ul>\\r\\n<h3>Tiles&nbsp;या Live Tiles:-</h3>\\r\\n<p>ये &nbsp;चौकोर या आयताकार शेप के होते है । टाइल शेप होने के कारण इन्&zwj;हें &nbsp;टाइल कहते है । विंडो 8.1 में &nbsp;ये स्&zwj;टार्ट स्&zwj;क्रीन में ग्रिड के पैटर्न में उपस्थित होते है। &nbsp;ये विंडो-८ में उपलब्&zwj;ध एप को प्रदर्शित करते है, जैसे &ndash; Desktop applications, Web Pages, Explorer folder locations या विंडो स्&zwj;टोर में उपलब्&zwj;ध अन्&zwj;य सुविधायें ।</p>\\r\\n<p>टाइल में कई तरह की आवश्&zwj;यक जानकारी मिल जाती है जैसे इमेंल एप्लिकेशन में आये न पढे गये मेल की सूची .वर्तमान तापमान ,मौसम की जानकारी, कैलेंडर अप्लिकेशन से एप्&zwj;वाइमेंट की सूची ।</p>\\r\\n<h3>Hot corner:-</h3>\\r\\n<p>विंडो 8.1 में हॉट कॉर्नर का उपयोग करके नेविगेट किया जा सकता है, स्&zwj;क्रीन के कोने पर माउस को घुमाने पर एक टूलबार या टाइल होता है, जिसे क्लिक कर सकते है। प्रत्&zwj;येक कार्नर से अलग अलग कार्य होते है &ndash;</p>\\r\\n<p>Lower Left :-&nbsp; निचले बायें काने के हॉट कॉर्नर पर क्लिक करके स्&zwj;टार्ट स्क्रीन पर वापस &nbsp;आ सकते है ।</p>\\r\\n<p>Uper Left :-&nbsp; उपरी बायें कोने पर क्लिक करके पिछले एप पर जा सकते हैं। &nbsp;</p>\\r\\n<h3>Charms Bar:-</h3>\\r\\n<p>विंडोज 8.1 में चार्म्स बार एक ऐसा आसान&nbsp; विकल्&zwj;प है जिसके उपयोग से&nbsp; किसी सामग्री की खोज, साझा करने, स्&zwj;टार्ट स्&zwj;क्रीन पर जाने, किसी दूसरी डिवाइस&nbsp; पर सामग्री भेजने और ऐप्स की सेटिंग्स बदली जा सकती है ।</p>\\r\\n<p>&nbsp;इसमें समय, तारीख, बैटरी की स्थिती, इंटरनेट की उपलब्&zwj;धता प्रर्दशित होती है। इसकी विंडो बटन से स्&zwj;टार्ट स्&zwj;क्रीन पर जा सकते है।&nbsp;</p>\\r\\n<p>चार्मस बार पर दाहिनी किनारे पर स्&zwj;वाइप , माउस हावर करके या Windows-C, बटन प्रेस करके जाया जा सकता है।</p>\\r\\n<p>कर्सर को द&zwj;ाहिने कोने पर रखकर उपर या नीचे स्&zwj;क्रीन के केंद्र की ओर सरकाकर भी चार्मस बार ओपन कर सकते है।&nbsp; कुछ चार्मस के कुछ शार्ट कट भी होते हैं। टेबलेट में इसे चार्मस बार खोलने के लिए राइट से Swip कर सकते है।</p>\\r\\n<h4>सर्च चार्म &ndash;</h4>\\r\\n<p>कंप्यूटर, सेटिंग्स, फ़ाइलों या किसी विंडोज 8 स्टाइल ऐप के अंदर &nbsp;खोजने के लिए इस चार्मस&nbsp; का उपयोग करते हैं । ड्रॉप-डाउन मेनू खोलकर और जिस विकल्प से आप खोजना चाहते हैं उसे चुनकर बस अपना इच्छित विकल्प चुनें: To use the Search चार्म का उपयोग सभी जगह से करने के लिये Windows-Q या Windows-S प्रेस करें । Search चार्म का शार्टकट Windows-W है। files सर्च करने का शार्ट कट Windows-F है।</p>\\r\\n<h4>शेयर चार्म &ndash;</h4>\\r\\n<p>शेयर चार्म का उपयोग अधिकांश ऐप्स से दस्तावेज़ शेयर करने के लिये होता है। सभी ऐप्स से स्क्रीनशॉट और विंडोज स्टोर ऐप्स में&nbsp; स्टोर पेज के लिंक साझा करने के लिए इस चार्म का उपयोग कर सकते हैं । &nbsp;अपना विकल्प चुनने के बाद, उस ऐप के नाम पर क्लिक करें जिसे जानकारी भेजना हैं:<br>Share Charm का शार्टकट Windows-H है।</p>\\r\\n<h4>Devices Charm&nbsp; &ndash;</h4>\\r\\n<p>इस चार्म की सहायता से सामग्री दूसरी डिवाइस में भेजी जाती है।&nbsp; प्&zwj;ले आप्&zwj;शन से आडियो फाइल किसी दूसरी डिवाइस में चलाइ जा सकती है। प्रिंट आप्&zwj;शन से फाइल प्रिंट कर सकते है। प्रोजेक्&zwj;ट आप्&zwj;शन से प्रोजेक्&zwj;टर उपयोग किया जा सकता है। &nbsp;&nbsp;Windows-K&nbsp; Devices Charm खोलने का शार्टकट है। &nbsp;</p>\\r\\n<h4>The Settings Charm &ndash;</h4>\\r\\n<p>इससे एप की सेटिंग में जाया जा सकता है। वे संटिंग जो पहले प्रिफरेंसेस के अंदर थी सेटिंग चार्मस के अंदर है। इसमें internet, sound, screen brightness, notifications, shutdown , restart, और &nbsp;keyboard के आप्&zwj;शन होते है। Settings Charm का शार्टकट &nbsp;Windows-I है।</p>\\r\\n<h3>How to start, login, logoff, Hibernate, Shutdown, Restart:-</h3>\\r\\n<h3>स्&zwj;टार्ट करना :-</h3>\\r\\n<p>कम्&zwj;प्&zwj;यूटर स्&zwj;टार्ट करने की प्रोसेस को बूटिंग कहते हैं। सीपीयू का स्&zwj;वीच ऑन करने पर कम्प्&zwj;यूटर अपने पार्टस चेक करता हैं, &nbsp;इसके&nbsp; बाद ऑपरेटिगं सिस्&zwj;टम को बूटस्&zwj;टेप लोडिंग की मदद से लोड करता हैं।</p>\\r\\n<p>इस प्रक्रिया में कम्&zwj;प्&zwj;यूटर प्रोसेसर की क्षमता के अनुसार कुछ सेकेण्&zwj;ड से कुछ मिनट तक का समय लगता हैं, इस प्रक्रिया &nbsp;को बूटिंग कहते हैं।</p>\\r\\n<h3>शट डाउन:-</h3>\\r\\n<p>स्&zwj;टार्ट बटन मे जाकर शट डाउन ऑप्&zwj;सन पर क्लिक करने से कम्&zwj;प्&zwj;यूटर के बंद होने की प्रक्रिया शुरू होगी, जिसमे कम्&zwj;प्&zwj;यूटर क्रम से अपने खुले हुए सॉफ्टवेयर को बंद करेगा, एंव ऑपरेटिगं सिस्&zwj;टम को अनलोड करेगा । इसके बाद कम्&zwj;प्&zwj;यूटर पावर आफ कर देगा।</p>\\r\\n<h3>रिस्&zwj;टार्ट करना:-</h3>\\r\\n<p>कुछ शाफटवेयर आवश्&zwj;यकता के अनुसार कई बार कम्&zwj;प्&zwj;यूटर के शट डाउन करके दुबारा तुरंत रिस्&zwj;टार्ट करना पड़ता है। शटडाउन के नीचे रीस्&zwj;टार्ट बटन से इसे किया जाता है।</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">start &ndash;&gt; shut down &ndash;&gt; restart&ndash;&gt; ok</p>\\r\\n<h3>Hibernate करना :-</h3>\\r\\n<p>यह ऑप्&zwj;सन लेपटॉप में उपलब्&zwj;ध होता हैं जब कभी लेपटॉप काफी देर बाद उपयोग करना है तो इस ऑप्&zwj;सन का प्रयोग करते हैं। कम्&zwj;प्&zwj;यूटर हाइबरनेट करने के पश्&zwj;चात दुबारा ओपन करने पर अपनी पुरानी स्थिति में वापस स्&zwj;टार्ट होता हैं। अर्थात &nbsp;हाइबरनेट करते समय जो भी प्रोग्राम और फाइल ओपन थी वह दुबारा ओपन हो जाएगी।</p>\\r\\n<h3>लागिन &ndash;</h3>\\r\\n<p>अगर किसी एक कम्&zwj;प्&zwj;यूटर को एक से ज्&zwj;यादा लोग प्रयोग कर रहे हैं तो सभी यूसर अपना अलग अलग एकाउंट बना सकते है। इससे यूसर एक दूसरे की फाइल नहीं देख सकता । यूसर अपना एकाउंट स्&zwj;टार्ट होते समय लागिन करना पड़ता है। &nbsp;इसके लिये उसे अपना आइडी एवं पासवर्ड डालना पड़ता है। कार्य समाप्&zwj;त होने पर वह स्&zwj;टार्ट स्&zwj;क्रीन के लागआउट बटन केा प्रेस करके अपने एकाउंट को क्&zwj;लोस कर देता है। दूसरा यूसर अपना आई डी एवं पासवर्ड डालकर अपने एकाउंट में लागिन होकर कार्य करेगा।</p>\\r\\n<h4>डेस्&zwj;कटॉप बैकग्राउण्&zwj;ड:-</h4>\\r\\n<ul>\\r\\n<li>कम्&zwj;प्&zwj;यूटर स्&zwj;टार्ट होने पर जो पहली स्&zwj;क्रीन दिखती हैं उसे डेस्&zwj;कटॉप कहते हैं।</li>\\r\\n<li>इस स्&zwj;क्रीन पर हम अपनी पंसद की फोटो सेट कर सकते है। इस पिक्&zwj;चर, कलर या फोटो को डेस्&zwj;कटॉप बैकराउण्&zwj;ड कहते हैं।</li>\\r\\n<li>डेस्&zwj;कटॉप&nbsp; बैकराउण्&zwj;ड चेंज करने के लिए स्&zwj;क्रीन की ख़ाली जगह पर राइट क्लिक करे ओपन हुए डॉयलाग बॉक्&zwj;स या मेन्&zwj;यू पर में डेस्&zwj;कटॉप बैकराउण्&zwj;ड में क्लिक करे।</li>\\r\\n<li>ब्राउज करके अपनी पंसद की फोटो सलेक्&zwj;ट करे।</li>\\r\\n<li>इमेज पर राइट क्लिक करे खुले हुए ऑप्&zwj;सन में सेट एस वॉलपेपर पर क्लिक करे।</li>\\r\\n</ul>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\"><img src=\\"https://hamararewa.in/unit-i-operating-system/\\" width=\\"19\\" height=\\"14\\"><img src=\\"https://hamararewa.in/unit-i-operating-system/\\" width=\\"16\\" height=\\"14\\"><img src=\\"https://hamararewa.in/unit-i-operating-system/\\" width=\\"19\\" height=\\"14\\">Start&nbsp;&ndash;&gt; Control Panel&nbsp;&ndash;&gt;&nbsp; Personalization&nbsp;&nbsp;&ndash;&gt;&nbsp;&nbsp;background &ndash;&gt; chose your picture</p>\\r\\n<h4>स्&zwj;क्रीन सेवर:-</h4>\\r\\n<p>जब कभी हम कम्&zwj;प्&zwj;यूटर को खाली छ़ोडते हैं तो उसकी स्&zwj;क्रीन पर कोई पिक्&zwj;चर या फोटो टेक्&zwj;स्&zwj;ट रोटेट करता हुआ दिखाई देता है इसे स्&zwj;क्रीन सेवर कहते हैं।</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Start&nbsp;&ndash;&gt;&nbsp;&nbsp;setting&ndash;&gt; personalization &ndash;&gt;Lock screen &ndash;&gt; select screen saver setting</p>\\r\\n<h4>डेस्&zwj;कटॉप थीम :-</h4>\\r\\n<p>यह एक कस्&zwj;टमाइज ग्राफिकल यूजर इन्&zwj;टफेस है, जो कम्&zwj;प्&zwj;यूटर के ऑर्डनरी साउण्&zwj;ड, आइकॉन, पॉइन्&zwj;टर, वॉल पेपर, या स्&zwj;क्रीन सेवर को एक साथ अपनी पंसद के अनुसार बदल सकते हैं।</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Start&nbsp;&ndash;&gt;&nbsp;&nbsp;setting&ndash;&gt; personalization &ndash;&gt;Themes&ndash;&gt; change theme &ndash;&gt; chose theme</p>\\r\\n<h4>फाइल:-</h4>\\r\\n<p>यह एक आब्&zwj;जेक्&zwj;ट है जिसमे कम्&zwj;प्&zwj;यूटर किसी प्रोग्राम के साथ बनाए गए डाटा, सूचना, सेंटिग या निर्देश को सेव करके रखता है। जिस अप्लिकेशन &nbsp;में फाइल बनाई जा रही है उसी के अनुसार उस फाइल का इक्&zwj;सटेंशन &nbsp;बन जाता है।</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">aruncomputer.txt&nbsp;&nbsp;&nbsp;&nbsp;&ndash;&gt;&nbsp;&nbsp;notepad&nbsp;&nbsp;&nbsp;में बनी ,</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">aruncomputer.doc&nbsp;&nbsp;&nbsp;&ndash;&gt;&nbsp;&nbsp;MS Word&nbsp;&nbsp;&nbsp;में बनी&nbsp;</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">arun.xls&nbsp;&nbsp;&ndash;&gt;&nbsp;&nbsp;&nbsp;Ms Excel&nbsp;&nbsp;में बनी</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">arun.jpg&nbsp;&nbsp;&nbsp;&nbsp;&ndash;&gt;&nbsp;&nbsp;&nbsp;Image&nbsp;&nbsp;File</p>\\r\\n<h4>फोल्&zwj;डर:-</h4>\\r\\n<p>यह एक विशेष प्रकार की फाइल है जिसमे अन्&zwj;य फाइल और फोल्&zwj;डर रखे जा सकते है।</p>\\r\\n<ul>\\r\\n<li>फोल्&zwj;डर एक ऐसा आब्&zwj;जेक्&zwj;ट है, जिसमे कई दस्&zwj;तावेज हो सकते है।</li>\\r\\n<li>फोल्&zwj;डर के उपयोग से जानकारी को व्&zwj;यवस्थित किया जाता है।</li>\\r\\n<li>फोल्&zwj;डर किसी दूसरे फोल्&zwj;डर के अंदर या डायरेक्&zwj;ट्री में रहता है।</li>\\r\\n</ul>\\r\\n<h4>नया फोल्&zwj;डर बनाना :-</h4>\\r\\n<ol>\\r\\n<li>जिस जगह ड्राइव, डायरेक्&zwj;ट्री या फोल्&zwj;डर के अंदर फोल्&zwj;डर बनाना है वहॅा पर ब्राउज करके जाएगे।</li>\\r\\n<li>खाली स्&zwj;थान पर माउस से राइट क्लिक करेगे।</li>\\r\\n<li>खुली हुई ड्रॉप डाउन मेन्&zwj;यू से नए फोल्&zwj;डर New Folder पर क्लिक करेगे।</li>\\r\\n<li>नया फोल्&zwj;डर बन जाएगा उसके आइकॉन पर नीचे कर्सर आयेगा यहां फोल्&zwj;डर का &nbsp;नाम टाइप करेगें।</li>\\r\\n</ol>\\r\\n<h4>फाइल या फोल्&zwj;डर डिलीट करना :-</h4>\\r\\n<ol>\\r\\n<li>जिस फाइल या फोल्&zwj;डर को डिलीट करना है ब्राउज करके उस तक जाएगे।</li>\\r\\n<li>फोल्&zwj;डर या फाइल पर राइट क्लिक करेगे।</li>\\r\\n<li>खुले हुए ड्रॉप डाउन मेन्&zwj;यू से डिलीट बटन पर क्लिक करेगे।</li>\\r\\n<li>Conformation Window में Ok/yes पर क्लिक करेगे। &mdash; &gt; Or</li>\\r\\n<li>फाइल फोल्&zwj;डर सलेक्&zwj;ट करके Keyboard से डिलीट बटन दबा देगे।</li>\\r\\n<li>Yes/Ok Click करेगे।</li>\\r\\n</ol>\\r\\n<h4>Right click on folder &ndash;&gt; press delete button on dropdown menu &ndash;&gt; ok /yes</h4>\\r\\n<h4>फाइल या फोल्&zwj;डर को मूव और कॉपी करना:-</h4>\\r\\n<ol>\\r\\n<li>फाइल या फोल्&zwj;डर को एक स्&zwj;थान से दूसरे स्&zwj;थान पर ले जाने के लिए Cut/Paste का उपयोग करते है।</li>\\r\\n<li>कॉपी करके दूसरी जगह Paste करने पर फाइल दोनो स्&zwj;थान पर रहेगी।</li>\\r\\n<li>Cut करके Paste करने पर फाइल पहले स्&zwj;थान से हट कर नई जगह पर Paste हो जाएगी।</li>\\r\\n<li>जिस फाइल या फोल्&zwj;डर को Move करना है उस पर राइट क्लिक करके Cut/Copy ऑप्&zwj;सन सलेक्&zwj;ट करेगे।</li>\\r\\n<li>जिस जगह फाइल या फोल्&zwj;डर को ले जाना है वहॉ राइट क्लिक करेगे ड्रॉप डाउन मेन्&zwj;यू से Paste Option select करेगे।</li>\\r\\n</ol>\\r\\n<h4>फोल्&zwj;डर Rename करना:-</h4>\\r\\n<ol>\\r\\n<li>फाइल या फोल्&zwj;डर पर राइट क्लिक करेगे।</li>\\r\\n<li>ड्रॉप डाउन मेन्&zwj;यू से Rename Option पर क्लिक करेगे।</li>\\r\\n<li>कर्सर फाइल या फोल्&zwj;डर के नाम पर Blink करने लगेगा।</li>\\r\\n<li>पुराना नाम मिटाकर नया नाम टाइप करेगे।</li>\\r\\n</ol>\\r\\n<h4>Right click on folder &ndash;&gt; press rename button on dropdown menu &ndash;&gt; type new name</h4>\\r\\n<h4>Short Cut बनाना :-</h4>\\r\\n<ol>\\r\\n<li>जिस फाइल का Short cut बनाना है उस पर राइट क्लिक करेगे।</li>\\r\\n<li>Drop down menu से Send to desktop option पर क्लिक करेगे।</li>\\r\\n</ol>\\r\\n<div>\\r\\n<div><a href=\\"https://hamararewa.in/pgdca-pcpackage/\\">Back</a></div>\\r\\n<div><a href=\\"https://hamararewa.in/unit-i-accessories-ms-paint-notepad-etc/\\">Next</a></div>\\r\\n</div>\\r\\n</div>\\r\\n</div>\\r\\n<h4>Recycle Bin :-</h4>\\r\\n<p>यह हमारे ऑपरेटिंग सिस्&zwj;टम में एक विशेष प्रकार का फोल्&zwj;डर होता है। हमारे द्वरा डिलीट की गई फाइल या फोल्&zwj;डर Recylcle Bin में चला जाता है।</p>\\r\\n<p>भविष्&zwj;य में आवश्&zwj;यकता पड़ने पर डिलीट की हुई फाइल Recycle Bin से Restore कि जा सकती है।</p>\\r\\n<p>Recycle Bin के अंदर जाकर फाइल या फोल्&zwj;डर को Permanently या स्&zwj;थाई रूप से डिलीट किया जा सकता है। &lsquo;Empty Recycle Bin&rsquo; Option से Recycle Bin में उपस्थित सभी फाइल एक साथ डिलीट हो जाती है।</p>\\r\\n<h3>Exam Question :</h3>\\r\\n<p>1- विडोज ऑपरेटिंग सिस्&zwj;टम और इसकी बुनियादी विशेषताओं को परिभाषित कीजिए। &ndash;&nbsp;<strong>मई (2025)</strong></p>\\r\\n<p>2- विंडोज ऐक्&zwj;सेसरीज में परिभाषित कोई पॉंच&nbsp; टूल्&zwj;स विस्&zwj;तार से लिखिए। &ndash;<strong>मई (2025)</strong></p>\\r\\n<p>3-विडोंज में कट्रोंल पैनल के महत्&zwj;व को समझाइए। &ndash;<strong>मई (2025)</strong></p>\\r\\n<p>4- कैश मेमोरी का कार्य क्&zwj;या है? &ndash;<strong>मई (2025)</strong></p>\', \'2026-03-01 06:10:59\', \'2026-03-01 06:10:59\')')
 2 SYSTEMPATH/Database/BaseConnection.php(652): CodeIgniter\Database\BaseConnection->simpleQuery('INSERT INTO `chapters` (`unit_id`, `name`, `slug`, `content`, `created_at`, `updated_at`) VALUES (\'2\', \'Operating system\', \'operating-system\', \'<div>\\r\\n<div>\\r\\n<h2>हार्डवेयर क्&zwj;या है :-&nbsp;</h2>\\r\\n<p>हार्डवेयर कम्&zwj;प्&zwj;यूटर के बाहरी और आंतरिक उपकरणों को कहते है। ये कम्&zwj;प्&zwj;यूटर के भौतिक भाग होते है। इन उपकरणों के द्वारा कम्&zwj;प्&zwj;यूटर इनपुट, आउटपुट, स्टोरेज, संचार, प्रोसेसिंग जैसे बहतु से प्रमुख कार्य करने में सक्षम होते है। कंप्यूटर हार्डवेयर दो प्रकार के होते हैं: बाहरी और आंतरिक। मानीटर , माउस , कीबोर्ड , हार्ड डिस्&zwj;क, रैम , मदरबोर्ड , प्रासेसर जैसे कम्&zwj;प्&zwj;यूटर के हिस्&zwj;से हार्डवेयर कहलाते है।</p>\\r\\n<h2>सॉफ़्टवेयर क्&zwj;या है :-</h2>\\r\\n<p>सॉफ़्टवेयर के द्वारा कम्&zwj;प्&zwj;यूटर हार्डवेयर केा निर्देश दिया जाता है, कि उसे क्&zwj;या करना है, और कैसे करना है। किसी विशेष कार्य को करने के लिए निर्देषों के समूह को प्रोग्राम कहते है, एक सॉफ़्टवेयर में बहुत से छोटे छोट प्रोग्राम हो सकते है, जो समुहिक रूप से मिलकर एक बड़ा कार्य कर सकते है । कम्&zwj;प्&zwj;यूटर के प्रोग्राम एवं मोबाइल के एप सॉफ़्टवेयर कहलाते है।</p>\\r\\n<h3>Software के प्रकार निम्&zwj;नलिखित है:-</h3>\\r\\n<h3>Application Software :-&nbsp;</h3>\\r\\n<p>&nbsp;&ldquo;एप्लिकेशन सॉफ़्टवेयर&rdquo; कम्&zwj;प्&zwj;यूटर उपयोग करने वाले के लिए विशिष्ट कार्य करता है। एप्लिकेशन सॉफ़्टवेयर को यूजर सीधे उपयोग करता है । एप्लिकेशन सॉफ़्टवेयर का उद्देश्य किसी विशिष्&zwj;ट कार्यों को करने में उपयोगकर्ता को &nbsp;सहायता प्रदान करना है।</p>\\r\\n<p>माइक्रोसॉफ्ट वर्ड एक्सेल, फ़ायरफ़ॉक्स और गूगल क्रोम वेब ब्राउज़र, मोबाइल ऐप्स व्हाट्सएप और कैंडी क्रश सागा जैसे गेम एप्लिकेशन सॉफ़्टवेयर के उदाहरण हैं।</p>\\r\\n<p>लोकप्रिय सेवाओं के ऐप जैसे मौसम या परिवहन जानकारी, ग्लोबल पोजिशनिंग सिस्टम (जीपीएस), ग्राफिक्स, मल्टीमीडिया, प्रेजेंटेशन सॉफ्टवेयर, डेस्कटॉप पब्लिशिंग सॉफ्टवेयर इत्यादि &nbsp;अप्लिकेशन&nbsp; सॉफ्टवेयर के उदाहरण हैं।</p>\\r\\n<h3>System software &ndash;</h3>\\r\\n<p>सिस्टम सॉफ़्टवेयर का उपयोग हार्डवेयर के साथ इंटरैक्ट करने के लिए किया जाता है। ये सॉफ़्टवेयर अन्य सॉफ़्टवेयर के लिए एक प्लेटफ़ॉर्म प्रदान करते है। सिस्टम सॉफ़्टवेयर हार्डवेयर और उपयोगकर्ता के बीच माध्&zwj;यम के रूप में कार्य करता है।ये आमतौर पर कंप्यूटर निर्माताओं द्वारा तैयार किए जाते हैं। इस सॉफ़्टवेयर में निम्न-स्तरीय भाषाओं में लिखे गए प्रोग्राम भी आते हैं,</p>\\r\\n<p>ऑपरेटिंग सिस्टम, एंटीवायरस सॉफ़्टवेयर, डिस्क फ़ॉर्मेटिंग सॉफ़्टवेयर, कंप्यूटर भाषा अनुवादक, डिवाइस ड्राइवर इत्&zwj;यादि सिस्टम सॉफ़्टवेयर के उदाहरण हैं।</p>\\r\\n<h2>Operating system:-</h2>\\r\\n<p>ऑपरेटिंग सिस्&zwj;टम एक &lsquo;सिस्&zwj;टम Software&rsquo; है जो कम्&zwj;प्&zwj;यूटर का आन्&zwj;तरिक संचालन करता है। यह कम्&zwj;प्&zwj;यूटर को हमारे उपयोग के लिए तैयार करता है। यह कम्&zwj;प्&zwj;यूटर स्&zwj;टार्ट करने पर बूट प्रोग्राम द्वारा कंप्यूटर में लोड होता है ।</p>\\r\\n<p>यह कंप्यूटर के हार्डवेयर एवं अन्य सभी एप्लिकेशन प्रोग्राम को संचालित करता है। उपयोगकर्ता कमांड-लाइन इंटरफ़ेस (सीएलआई) या ग्राफिकल यूआई (जीयूआई) के माध्यम से ऑपरेटिंग सिस्टम को निर्देश दे सकते है ।</p>\\r\\n<h3>Window 8.1:-</h3>\\r\\n<p>ऑपरेटिंग सिस्&zwj;टम एक सिस्&zwj;टम Software है जो कम्&zwj;प्&zwj;यूटर का आन्&zwj;तरिक संचालन करता है। यह कम्&zwj;प्&zwj;यूटर को हमारे उपयोग के लिए तैयार करता है। यह कम्&zwj;प्&zwj;यूटर स्&zwj;टार्ट करने पर बूट प्रोग्राम द्वारा कंप्यूटर में लोड होता है ।</p>\\r\\n<ul>\\r\\n<li>Window 8.1 एक ऑपरेटिगं सिस्&zwj;टम है जिसे माइक्रोसॉफ्ट कम्&zwj;पनी ने बनाया है।</li>\\r\\n<li>विंडो ऑपरेटिंग सिस्&zwj;टम में प्रोग्राम एक विंडो में खुलते है।</li>\\r\\n<li>एक साथ कई प्रोग्राम अलग- अलग विंडो में खोले जा सकते है। इसलिए इसे विंडो ऑपरेटिंग सिस्&zwj;टम कहते है।</li>\\r\\n<li>पुराने ऑपरेटिंग सिस्&zwj;टम में (Dos Based) कम्&zwj;प्&zwj;यूटर को कमाण्&zwj;ड या निर्देश टाइप करके दिया जाता था।</li>\\r\\n<li>जिसके कारण हमे सारे कमाण्&zwj;ड याद रखने पड़ते थे। विंडो ऑपरेटिंग सिस्&zwj;टम के विकास के बाद हम कम्&zwj;प्&zwj;यूटर को निर्देश मानीटर पर आइकॉन के उपर&nbsp; क्लिक करके दे सकते &nbsp;है।</li>\\r\\n<li>विंडो 8.1 में पुराने विंडो के संस्&zwj;करण विंडो 8 तक की सभी सुविधाए उपलब्&zwj;ध है, यह ज्&zwj;यादा एडवांस और स्&zwj;टेबल है। इसमे नए ऑनलाइन फीचर और सिक्&zwj;योरिटी जोड़ी गई है।</li>\\r\\n<li>इसका इन्&zwj;टरफेस नया है। इसमे लाइव टाइल और हॉट कॉर्नरस की सुविधाए दी गई है।</li>\\r\\n<li>हमारें प्रोग्राम को सुरक्षित रखने व वायरस से बचाने के लिए विंडो डिफेन्&zwj;डर एन्&zwj;टीवायरस उपलब्&zwj;ध कराया गया है।</li>\\r\\n</ul>\\r\\n<h3>Tiles&nbsp;या Live Tiles:-</h3>\\r\\n<p>ये &nbsp;चौकोर या आयताकार शेप के होते है । टाइल शेप होने के कारण इन्&zwj;हें &nbsp;टाइल कहते है । विंडो 8.1 में &nbsp;ये स्&zwj;टार्ट स्&zwj;क्रीन में ग्रिड के पैटर्न में उपस्थित होते है। &nbsp;ये विंडो-८ में उपलब्&zwj;ध एप को प्रदर्शित करते है, जैसे &ndash; Desktop applications, Web Pages, Explorer folder locations या विंडो स्&zwj;टोर में उपलब्&zwj;ध अन्&zwj;य सुविधायें ।</p>\\r\\n<p>टाइल में कई तरह की आवश्&zwj;यक जानकारी मिल जाती है जैसे इमेंल एप्लिकेशन में आये न पढे गये मेल की सूची .वर्तमान तापमान ,मौसम की जानकारी, कैलेंडर अप्लिकेशन से एप्&zwj;वाइमेंट की सूची ।</p>\\r\\n<h3>Hot corner:-</h3>\\r\\n<p>विंडो 8.1 में हॉट कॉर्नर का उपयोग करके नेविगेट किया जा सकता है, स्&zwj;क्रीन के कोने पर माउस को घुमाने पर एक टूलबार या टाइल होता है, जिसे क्लिक कर सकते है। प्रत्&zwj;येक कार्नर से अलग अलग कार्य होते है &ndash;</p>\\r\\n<p>Lower Left :-&nbsp; निचले बायें काने के हॉट कॉर्नर पर क्लिक करके स्&zwj;टार्ट स्क्रीन पर वापस &nbsp;आ सकते है ।</p>\\r\\n<p>Uper Left :-&nbsp; उपरी बायें कोने पर क्लिक करके पिछले एप पर जा सकते हैं। &nbsp;</p>\\r\\n<h3>Charms Bar:-</h3>\\r\\n<p>विंडोज 8.1 में चार्म्स बार एक ऐसा आसान&nbsp; विकल्&zwj;प है जिसके उपयोग से&nbsp; किसी सामग्री की खोज, साझा करने, स्&zwj;टार्ट स्&zwj;क्रीन पर जाने, किसी दूसरी डिवाइस&nbsp; पर सामग्री भेजने और ऐप्स की सेटिंग्स बदली जा सकती है ।</p>\\r\\n<p>&nbsp;इसमें समय, तारीख, बैटरी की स्थिती, इंटरनेट की उपलब्&zwj;धता प्रर्दशित होती है। इसकी विंडो बटन से स्&zwj;टार्ट स्&zwj;क्रीन पर जा सकते है।&nbsp;</p>\\r\\n<p>चार्मस बार पर दाहिनी किनारे पर स्&zwj;वाइप , माउस हावर करके या Windows-C, बटन प्रेस करके जाया जा सकता है।</p>\\r\\n<p>कर्सर को द&zwj;ाहिने कोने पर रखकर उपर या नीचे स्&zwj;क्रीन के केंद्र की ओर सरकाकर भी चार्मस बार ओपन कर सकते है।&nbsp; कुछ चार्मस के कुछ शार्ट कट भी होते हैं। टेबलेट में इसे चार्मस बार खोलने के लिए राइट से Swip कर सकते है।</p>\\r\\n<h4>सर्च चार्म &ndash;</h4>\\r\\n<p>कंप्यूटर, सेटिंग्स, फ़ाइलों या किसी विंडोज 8 स्टाइल ऐप के अंदर &nbsp;खोजने के लिए इस चार्मस&nbsp; का उपयोग करते हैं । ड्रॉप-डाउन मेनू खोलकर और जिस विकल्प से आप खोजना चाहते हैं उसे चुनकर बस अपना इच्छित विकल्प चुनें: To use the Search चार्म का उपयोग सभी जगह से करने के लिये Windows-Q या Windows-S प्रेस करें । Search चार्म का शार्टकट Windows-W है। files सर्च करने का शार्ट कट Windows-F है।</p>\\r\\n<h4>शेयर चार्म &ndash;</h4>\\r\\n<p>शेयर चार्म का उपयोग अधिकांश ऐप्स से दस्तावेज़ शेयर करने के लिये होता है। सभी ऐप्स से स्क्रीनशॉट और विंडोज स्टोर ऐप्स में&nbsp; स्टोर पेज के लिंक साझा करने के लिए इस चार्म का उपयोग कर सकते हैं । &nbsp;अपना विकल्प चुनने के बाद, उस ऐप के नाम पर क्लिक करें जिसे जानकारी भेजना हैं:<br>Share Charm का शार्टकट Windows-H है।</p>\\r\\n<h4>Devices Charm&nbsp; &ndash;</h4>\\r\\n<p>इस चार्म की सहायता से सामग्री दूसरी डिवाइस में भेजी जाती है।&nbsp; प्&zwj;ले आप्&zwj;शन से आडियो फाइल किसी दूसरी डिवाइस में चलाइ जा सकती है। प्रिंट आप्&zwj;शन से फाइल प्रिंट कर सकते है। प्रोजेक्&zwj;ट आप्&zwj;शन से प्रोजेक्&zwj;टर उपयोग किया जा सकता है। &nbsp;&nbsp;Windows-K&nbsp; Devices Charm खोलने का शार्टकट है। &nbsp;</p>\\r\\n<h4>The Settings Charm &ndash;</h4>\\r\\n<p>इससे एप की सेटिंग में जाया जा सकता है। वे संटिंग जो पहले प्रिफरेंसेस के अंदर थी सेटिंग चार्मस के अंदर है। इसमें internet, sound, screen brightness, notifications, shutdown , restart, और &nbsp;keyboard के आप्&zwj;शन होते है। Settings Charm का शार्टकट &nbsp;Windows-I है।</p>\\r\\n<h3>How to start, login, logoff, Hibernate, Shutdown, Restart:-</h3>\\r\\n<h3>स्&zwj;टार्ट करना :-</h3>\\r\\n<p>कम्&zwj;प्&zwj;यूटर स्&zwj;टार्ट करने की प्रोसेस को बूटिंग कहते हैं। सीपीयू का स्&zwj;वीच ऑन करने पर कम्प्&zwj;यूटर अपने पार्टस चेक करता हैं, &nbsp;इसके&nbsp; बाद ऑपरेटिगं सिस्&zwj;टम को बूटस्&zwj;टेप लोडिंग की मदद से लोड करता हैं।</p>\\r\\n<p>इस प्रक्रिया में कम्&zwj;प्&zwj;यूटर प्रोसेसर की क्षमता के अनुसार कुछ सेकेण्&zwj;ड से कुछ मिनट तक का समय लगता हैं, इस प्रक्रिया &nbsp;को बूटिंग कहते हैं।</p>\\r\\n<h3>शट डाउन:-</h3>\\r\\n<p>स्&zwj;टार्ट बटन मे जाकर शट डाउन ऑप्&zwj;सन पर क्लिक करने से कम्&zwj;प्&zwj;यूटर के बंद होने की प्रक्रिया शुरू होगी, जिसमे कम्&zwj;प्&zwj;यूटर क्रम से अपने खुले हुए सॉफ्टवेयर को बंद करेगा, एंव ऑपरेटिगं सिस्&zwj;टम को अनलोड करेगा । इसके बाद कम्&zwj;प्&zwj;यूटर पावर आफ कर देगा।</p>\\r\\n<h3>रिस्&zwj;टार्ट करना:-</h3>\\r\\n<p>कुछ शाफटवेयर आवश्&zwj;यकता के अनुसार कई बार कम्&zwj;प्&zwj;यूटर के शट डाउन करके दुबारा तुरंत रिस्&zwj;टार्ट करना पड़ता है। शटडाउन के नीचे रीस्&zwj;टार्ट बटन से इसे किया जाता है।</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">start &ndash;&gt; shut down &ndash;&gt; restart&ndash;&gt; ok</p>\\r\\n<h3>Hibernate करना :-</h3>\\r\\n<p>यह ऑप्&zwj;सन लेपटॉप में उपलब्&zwj;ध होता हैं जब कभी लेपटॉप काफी देर बाद उपयोग करना है तो इस ऑप्&zwj;सन का प्रयोग करते हैं। कम्&zwj;प्&zwj;यूटर हाइबरनेट करने के पश्&zwj;चात दुबारा ओपन करने पर अपनी पुरानी स्थिति में वापस स्&zwj;टार्ट होता हैं। अर्थात &nbsp;हाइबरनेट करते समय जो भी प्रोग्राम और फाइल ओपन थी वह दुबारा ओपन हो जाएगी।</p>\\r\\n<h3>लागिन &ndash;</h3>\\r\\n<p>अगर किसी एक कम्&zwj;प्&zwj;यूटर को एक से ज्&zwj;यादा लोग प्रयोग कर रहे हैं तो सभी यूसर अपना अलग अलग एकाउंट बना सकते है। इससे यूसर एक दूसरे की फाइल नहीं देख सकता । यूसर अपना एकाउंट स्&zwj;टार्ट होते समय लागिन करना पड़ता है। &nbsp;इसके लिये उसे अपना आइडी एवं पासवर्ड डालना पड़ता है। कार्य समाप्&zwj;त होने पर वह स्&zwj;टार्ट स्&zwj;क्रीन के लागआउट बटन केा प्रेस करके अपने एकाउंट को क्&zwj;लोस कर देता है। दूसरा यूसर अपना आई डी एवं पासवर्ड डालकर अपने एकाउंट में लागिन होकर कार्य करेगा।</p>\\r\\n<h4>डेस्&zwj;कटॉप बैकग्राउण्&zwj;ड:-</h4>\\r\\n<ul>\\r\\n<li>कम्&zwj;प्&zwj;यूटर स्&zwj;टार्ट होने पर जो पहली स्&zwj;क्रीन दिखती हैं उसे डेस्&zwj;कटॉप कहते हैं।</li>\\r\\n<li>इस स्&zwj;क्रीन पर हम अपनी पंसद की फोटो सेट कर सकते है। इस पिक्&zwj;चर, कलर या फोटो को डेस्&zwj;कटॉप बैकराउण्&zwj;ड कहते हैं।</li>\\r\\n<li>डेस्&zwj;कटॉप&nbsp; बैकराउण्&zwj;ड चेंज करने के लिए स्&zwj;क्रीन की ख़ाली जगह पर राइट क्लिक करे ओपन हुए डॉयलाग बॉक्&zwj;स या मेन्&zwj;यू पर में डेस्&zwj;कटॉप बैकराउण्&zwj;ड में क्लिक करे।</li>\\r\\n<li>ब्राउज करके अपनी पंसद की फोटो सलेक्&zwj;ट करे।</li>\\r\\n<li>इमेज पर राइट क्लिक करे खुले हुए ऑप्&zwj;सन में सेट एस वॉलपेपर पर क्लिक करे।</li>\\r\\n</ul>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\"><img src=\\"https://hamararewa.in/unit-i-operating-system/\\" width=\\"19\\" height=\\"14\\"><img src=\\"https://hamararewa.in/unit-i-operating-system/\\" width=\\"16\\" height=\\"14\\"><img src=\\"https://hamararewa.in/unit-i-operating-system/\\" width=\\"19\\" height=\\"14\\">Start&nbsp;&ndash;&gt; Control Panel&nbsp;&ndash;&gt;&nbsp; Personalization&nbsp;&nbsp;&ndash;&gt;&nbsp;&nbsp;background &ndash;&gt; chose your picture</p>\\r\\n<h4>स्&zwj;क्रीन सेवर:-</h4>\\r\\n<p>जब कभी हम कम्&zwj;प्&zwj;यूटर को खाली छ़ोडते हैं तो उसकी स्&zwj;क्रीन पर कोई पिक्&zwj;चर या फोटो टेक्&zwj;स्&zwj;ट रोटेट करता हुआ दिखाई देता है इसे स्&zwj;क्रीन सेवर कहते हैं।</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Start&nbsp;&ndash;&gt;&nbsp;&nbsp;setting&ndash;&gt; personalization &ndash;&gt;Lock screen &ndash;&gt; select screen saver setting</p>\\r\\n<h4>डेस्&zwj;कटॉप थीम :-</h4>\\r\\n<p>यह एक कस्&zwj;टमाइज ग्राफिकल यूजर इन्&zwj;टफेस है, जो कम्&zwj;प्&zwj;यूटर के ऑर्डनरी साउण्&zwj;ड, आइकॉन, पॉइन्&zwj;टर, वॉल पेपर, या स्&zwj;क्रीन सेवर को एक साथ अपनी पंसद के अनुसार बदल सकते हैं।</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Start&nbsp;&ndash;&gt;&nbsp;&nbsp;setting&ndash;&gt; personalization &ndash;&gt;Themes&ndash;&gt; change theme &ndash;&gt; chose theme</p>\\r\\n<h4>फाइल:-</h4>\\r\\n<p>यह एक आब्&zwj;जेक्&zwj;ट है जिसमे कम्&zwj;प्&zwj;यूटर किसी प्रोग्राम के साथ बनाए गए डाटा, सूचना, सेंटिग या निर्देश को सेव करके रखता है। जिस अप्लिकेशन &nbsp;में फाइल बनाई जा रही है उसी के अनुसार उस फाइल का इक्&zwj;सटेंशन &nbsp;बन जाता है।</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">aruncomputer.txt&nbsp;&nbsp;&nbsp;&nbsp;&ndash;&gt;&nbsp;&nbsp;notepad&nbsp;&nbsp;&nbsp;में बनी ,</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">aruncomputer.doc&nbsp;&nbsp;&nbsp;&ndash;&gt;&nbsp;&nbsp;MS Word&nbsp;&nbsp;&nbsp;में बनी&nbsp;</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">arun.xls&nbsp;&nbsp;&ndash;&gt;&nbsp;&nbsp;&nbsp;Ms Excel&nbsp;&nbsp;में बनी</p>\\r\\n<p class=\\"has-text-align-center wp-block-paragraph\\">arun.jpg&nbsp;&nbsp;&nbsp;&nbsp;&ndash;&gt;&nbsp;&nbsp;&nbsp;Image&nbsp;&nbsp;File</p>\\r\\n<h4>फोल्&zwj;डर:-</h4>\\r\\n<p>यह एक विशेष प्रकार की फाइल है जिसमे अन्&zwj;य फाइल और फोल्&zwj;डर रखे जा सकते है।</p>\\r\\n<ul>\\r\\n<li>फोल्&zwj;डर एक ऐसा आब्&zwj;जेक्&zwj;ट है, जिसमे कई दस्&zwj;तावेज हो सकते है।</li>\\r\\n<li>फोल्&zwj;डर के उपयोग से जानकारी को व्&zwj;यवस्थित किया जाता है।</li>\\r\\n<li>फोल्&zwj;डर किसी दूसरे फोल्&zwj;डर के अंदर या डायरेक्&zwj;ट्री में रहता है।</li>\\r\\n</ul>\\r\\n<h4>नया फोल्&zwj;डर बनाना :-</h4>\\r\\n<ol>\\r\\n<li>जिस जगह ड्राइव, डायरेक्&zwj;ट्री या फोल्&zwj;डर के अंदर फोल्&zwj;डर बनाना है वहॅा पर ब्राउज करके जाएगे।</li>\\r\\n<li>खाली स्&zwj;थान पर माउस से राइट क्लिक करेगे।</li>\\r\\n<li>खुली हुई ड्रॉप डाउन मेन्&zwj;यू से नए फोल्&zwj;डर New Folder पर क्लिक करेगे।</li>\\r\\n<li>नया फोल्&zwj;डर बन जाएगा उसके आइकॉन पर नीचे कर्सर आयेगा यहां फोल्&zwj;डर का &nbsp;नाम टाइप करेगें।</li>\\r\\n</ol>\\r\\n<h4>फाइल या फोल्&zwj;डर डिलीट करना :-</h4>\\r\\n<ol>\\r\\n<li>जिस फाइल या फोल्&zwj;डर को डिलीट करना है ब्राउज करके उस तक जाएगे।</li>\\r\\n<li>फोल्&zwj;डर या फाइल पर राइट क्लिक करेगे।</li>\\r\\n<li>खुले हुए ड्रॉप डाउन मेन्&zwj;यू से डिलीट बटन पर क्लिक करेगे।</li>\\r\\n<li>Conformation Window में Ok/yes पर क्लिक करेगे। &mdash; &gt; Or</li>\\r\\n<li>फाइल फोल्&zwj;डर सलेक्&zwj;ट करके Keyboard से डिलीट बटन दबा देगे।</li>\\r\\n<li>Yes/Ok Click करेगे।</li>\\r\\n</ol>\\r\\n<h4>Right click on folder &ndash;&gt; press delete button on dropdown menu &ndash;&gt; ok /yes</h4>\\r\\n<h4>फाइल या फोल्&zwj;डर को मूव और कॉपी करना:-</h4>\\r\\n<ol>\\r\\n<li>फाइल या फोल्&zwj;डर को एक स्&zwj;थान से दूसरे स्&zwj;थान पर ले जाने के लिए Cut/Paste का उपयोग करते है।</li>\\r\\n<li>कॉपी करके दूसरी जगह Paste करने पर फाइल दोनो स्&zwj;थान पर रहेगी।</li>\\r\\n<li>Cut करके Paste करने पर फाइल पहले स्&zwj;थान से हट कर नई जगह पर Paste हो जाएगी।</li>\\r\\n<li>जिस फाइल या फोल्&zwj;डर को Move करना है उस पर राइट क्लिक करके Cut/Copy ऑप्&zwj;सन सलेक्&zwj;ट करेगे।</li>\\r\\n<li>जिस जगह फाइल या फोल्&zwj;डर को ले जाना है वहॉ राइट क्लिक करेगे ड्रॉप डाउन मेन्&zwj;यू से Paste Option select करेगे।</li>\\r\\n</ol>\\r\\n<h4>फोल्&zwj;डर Rename करना:-</h4>\\r\\n<ol>\\r\\n<li>फाइल या फोल्&zwj;डर पर राइट क्लिक करेगे।</li>\\r\\n<li>ड्रॉप डाउन मेन्&zwj;यू से Rename Option पर क्लिक करेगे।</li>\\r\\n<li>कर्सर फाइल या फोल्&zwj;डर के नाम पर Blink करने लगेगा।</li>\\r\\n<li>पुराना नाम मिटाकर नया नाम टाइप करेगे।</li>\\r\\n</ol>\\r\\n<h4>Right click on folder &ndash;&gt; press rename button on dropdown menu &ndash;&gt; type new name</h4>\\r\\n<h4>Short Cut बनाना :-</h4>\\r\\n<ol>\\r\\n<li>जिस फाइल का Short cut बनाना है उस पर राइट क्लिक करेगे।</li>\\r\\n<li>Drop down menu से Send to desktop option पर क्लिक करेगे।</li>\\r\\n</ol>\\r\\n<div>\\r\\n<div><a href=\\"https://hamararewa.in/pgdca-pcpackage/\\">Back</a></div>\\r\\n<div><a href=\\"https://hamararewa.in/unit-i-accessories-ms-paint-notepad-etc/\\">Next</a></div>\\r\\n</div>\\r\\n</div>\\r\\n</div>\\r\\n<h4>Recycle Bin :-</h4>\\r\\n<p>यह हमारे ऑपरेटिंग सिस्&zwj;टम में एक विशेष प्रकार का फोल्&zwj;डर होता है। हमारे द्वरा डिलीट की गई फाइल या फोल्&zwj;डर Recylcle Bin में चला जाता है।</p>\\r\\n<p>भविष्&zwj;य में आवश्&zwj;यकता पड़ने पर डिलीट की हुई फाइल Recycle Bin से Restore कि जा सकती है।</p>\\r\\n<p>Recycle Bin के अंदर जाकर फाइल या फोल्&zwj;डर को Permanently या स्&zwj;थाई रूप से डिलीट किया जा सकता है। &lsquo;Empty Recycle Bin&rsquo; Option से Recycle Bin में उपस्थित सभी फाइल एक साथ डिलीट हो जाती है।</p>\\r\\n<h3>Exam Question :</h3>\\r\\n<p>1- विडोज ऑपरेटिंग सिस्&zwj;टम और इसकी बुनियादी विशेषताओं को परिभाषित कीजिए। &ndash;&nbsp;<strong>मई (2025)</strong></p>\\r\\n<p>2- विंडोज ऐक्&zwj;सेसरीज में परिभाषित कोई पॉंच&nbsp; टूल्&zwj;स विस्&zwj;तार से लिखिए। &ndash;<strong>मई (2025)</strong></p>\\r\\n<p>3-विडोंज में कट्रोंल पैनल के महत्&zwj;व को समझाइए। &ndash;<strong>मई (2025)</strong></p>\\r\\n<p>4- कैश मेमोरी का कार्य क्&zwj;या है? &ndash;<strong>मई (2025)</strong></p>\', \'2026-03-01 06:10:59\', \'2026-03-01 06:10:59\')')
